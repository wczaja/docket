{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docket.dev/schemas/v1.json",
  "title": "docket Rubric v1",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^docket\\.dev/v[0-9]+$"
    },
    "kind": {
      "type": "string",
      "const": "Rubric"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "authors": {"type": "array", "items": {"type": "string"}},
        "description": {"type": "string"}
      }
    },
    "imports": {
      "type": "array",
      "items": {"type": "string"}
    },
    "modes": {
      "type": "array",
      "items": {"$ref": "#/$defs/mode"}
    },
    "clustering": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {"const": "per_mode_embedding"},
        "embedding_model": {"type": "string"},
        "similarity_threshold": {"type": "number", "minimum": 0, "maximum": 1},
        "min_cluster_size": {"type": "integer", "minimum": 2}
      }
    },
    "triage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto_post_threshold": {
          "enum": ["critical", "high", "medium", "low", "never"]
        },
        "default_severity_to_tracker": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        }
      }
    }
  },
  "$defs": {
    "mode": {
      "type": "object",
      "required": ["id", "severity", "detection"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "severity": {"enum": ["critical", "high", "medium", "low"]},
        "detection": {"$ref": "#/$defs/detection"},
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["trace_excerpt", "expected"],
            "additionalProperties": false,
            "properties": {
              "trace_excerpt": {"type": "string"},
              "context": {"type": "string"},
              "expected": {"enum": ["positive", "negative"]}
            }
          }
        }
      }
    },
    "detection": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {"enum": ["llm_judge", "regex", "tool_call", "metric_threshold", "composite"]},
        "prompt": {"type": "string"},
        "output_schema": {"type": "object"},
        "pattern": {"type": "string"},
        "tool_calls": {"type": "array", "items": {"type": "string"}},
        "metric": {"type": "string"},
        "threshold": {"type": "number"},
        "operator": {"enum": ["==", "!=", "<", "<=", ">", ">=", "and", "or"]},
        "operands": {"type": "array", "items": {"$ref": "#/$defs/detection"}},
        "model": {
          "type": "string",
          "description": "LLM provider URI like 'anthropic:claude-haiku-4-5-20251001'. Only consumed by llm_judge."
        }
      },
      "allOf": [
        {
          "if": {"properties": {"type": {"const": "llm_judge"}}, "required": ["type"]},
          "then": {
            "required": ["prompt", "output_schema"],
            "properties": {
              "output_schema": {
                "type": "object",
                "required": ["type", "required", "properties"],
                "properties": {
                  "type": {"const": "object"},
                  "required": {
                    "type": "array",
                    "contains": {"const": "positive"}
                  },
                  "properties": {
                    "type": "object",
                    "required": ["positive"],
                    "properties": {
                      "positive": {
                        "type": "object",
                        "required": ["type"],
                        "properties": {"type": {"const": "boolean"}}
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {"properties": {"type": {"const": "regex"}}, "required": ["type"]},
          "then": {"required": ["pattern"]}
        },
        {
          "if": {"properties": {"type": {"const": "tool_call"}}, "required": ["type"]},
          "then": {"required": ["tool_calls"]}
        },
        {
          "if": {"properties": {"type": {"const": "metric_threshold"}}, "required": ["type"]},
          "then": {
            "required": ["metric", "threshold", "operator"],
            "properties": {
              "operator": {"enum": ["==", "!=", "<", "<=", ">", ">="]}
            }
          }
        },
        {
          "if": {"properties": {"type": {"const": "composite"}}, "required": ["type"]},
          "then": {
            "required": ["operands", "operator"],
            "properties": {
              "operator": {"enum": ["and", "or"]},
              "operands": {"minItems": 2}
            }
          }
        }
      ]
    }
  }
}
